# iFretes Monorepo - Environment Variables Example

# --- API (NestJS) ---
PORT=4300
NODE_ENV=development

# Database (MariaDB - matching Hal-AI Zap local)
DB_HOST=127.0.0.1
DB_PORT=4330
DB_DATABASE=halaidb
DB_USERNAME=root
DB_PASSWORD=password

# Redis (Matching Hal-AI Zap local forward)
REDIS_HOST=127.0.0.1
REDIS_PORT=4637

# HALAI API
HALAI_API_URL=https://halaiapi.cwiz.com.br
HALAI_USERNAME=
HALAI_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- WEB (Vue 3) ---
VITE_API_URL=http://localhost:4300/api/v1
